{
  "name": "openteam",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "e2e:extension": "npm run build && node scripts/e2e-extension-smoke.mjs",
    "e2e": "npm run test:e2e && npm run e2e:extension",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run test:e2e && npm run build",
    "openteamctl": "node scripts/openteamctl.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "jsdom": "^29.1.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.75",
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@antv/x6": "^3.1.7",
    "@tiptap/core": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "ai": "^6.0.175",
    "markdown-it": "^14.1.1",
    "tslib": "^2.8.1"
  }
}
