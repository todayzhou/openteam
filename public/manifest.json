{
  "manifest_version": 3,
  "name": "OpenTeam",
  "version": "1.0.0",
  "description": "Multi-site AI team discussion panel",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "declarativeNetRequest", "clipboardRead", "clipboardWrite"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://*.gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://gemini.google.com https://*.gemini.google.com https://chatgpt.com https://*.chatgpt.com https://chat.openai.com https://claude.ai https://chat.deepseek.com;"
  },
  "action": {
    "default_title": "OpenTeam"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*", "*://*.gemini.google.com/*", "*://chatgpt.com/*", "*://*.chatgpt.com/*", "*://chat.openai.com/*", "*://claude.ai/*", "*://chat.deepseek.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ai_iframe_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
