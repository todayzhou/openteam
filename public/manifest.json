{
  "manifest_version": 3,
  "name": "OpenTeam",
  "version": "1.0.0",
  "description": "Gemini multi-agent team discussion panel",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs"],
  "action": {
    "default_title": "OpenTeam"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*", "*://*.gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
